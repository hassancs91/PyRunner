{
  "permissions": {
    "allow": [
      "Bash(dir:*)",
      "Bash(.\\\\venv\\\\Scripts\\\\pip install:*)",
      "Bash(d:/repos/PyRunner/venv/Scripts/pip.exe install:*)",
      "Bash(d:/repos/PyRunner/venv/Scripts/django-admin.exe startproject pyrunner .)",
      "Bash(d:/repos/PyRunner/venv/Scripts/python.exe:*)",
      "Bash(findstr:*)",
      "Bash(python manage.py tailwind:*)",
      "Bash(where:*)",
      "Bash(python:*)",
      "Bash(powershell -Command \"Get-ChildItem -Path . -Depth 2 -Exclude venv | Where-Object {$_PSIsContainer -or $_Extension -eq ''.py''} | Select-Object FullName\")",
      "Bash(powershell -Command \"Get-ChildItem -Exclude venv | Select-Object Name, @{Name=''Type''; Expression={if\\($_PSIsContainer\\){''Folder''}else{''File''}}}\")",
      "Bash(grep:*)",
      "Bash(wc:*)",
      "Bash(tree:*)"
    ]
  }
}
